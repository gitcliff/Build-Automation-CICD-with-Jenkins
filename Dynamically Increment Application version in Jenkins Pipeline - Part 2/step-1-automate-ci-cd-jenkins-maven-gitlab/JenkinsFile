// 📦 SUMMARY  
// This Jenkins pipeline automates the process of incrementing a Maven project version, building the Java app,  
// containerizing it into a Docker image, pushing the image to Docker Hub, and committing the updated version back to GitLab.  
// Language/Platform: Jenkins Declarative Pipeline (Groovy), Maven, Docker CLI, Git  
// What you'll learn: Maven version management, secure credential usage in Jenkins, Docker image build/push, Git configuration for CI pipelines.  
// Outcome: A versioned Docker image is built and pushed to Docker Hub, and the updated pom.xml version is committed to the GitLab repository.  
// Why this matters: Enables fully automated CI/CD with version tracking, consistent builds, and seamless deployment readiness.  

// ------------------------------  
// 🧩 PIPELINE DEFINITION  
// ------------------------------  
pipeline {  
    agent any                                         // ✅ Run on any available Jenkins agent.  

    tools {  
        maven 'maven-3.9'                             // ✅ What it does: Uses Maven 3.9 installed/configured in Jenkins for building Java projects  
                                                      // 🧠 Why it matters: Ensures consistent Maven version across builds for reliable packaging  
    }  

    stages {  
        stage('increment version') {  
            steps {  
                script {  
                    echo 'Incrementing app version...'  

                    // ✅ What it does: Uses Maven plugins to parse current pom version and increment patch version  
                    // 🧠 Why it matters: Automates versioning, avoiding manual errors and enabling traceable builds  
                    sh '''  
                    mvn build-helper:parse-version versions:set \  
                    -DnewVersion=\\\${parsedVersion.majorVersion}.\\\${parsedVersion.minorVersion}.\\\${parsedVersion.nextIncrementalVersion} \  
                    versions:commit  
                    '''  

                    // ✅ What it does: Reads updated version from pom.xml to create a Docker image tag  
                    // 🧠 Why it matters: Tags Docker images with version + build number for traceability  
                    def matcher = readFile('pom.xml') =~ '<version>(.+)</version>'  
                    def version = matcher[0][1]  
                    env.IMAGE_NAME = "${version}-${BUILD_NUMBER}"  // ✅ Sets environment variable for Docker tag  
                }  
            }  
        }  

        stage('build app') {  
            steps {  
                script {  
                    echo 'Building the application...'  

                    // ✅ What it does: Cleans previous Maven build and packages the app as a JAR  
                    // 🧠 Why it matters: Produces a fresh, consistent artifact for Docker image build  
                    sh 'mvn clean package'  
                }  
            }  
        }  

        stage('build image') {  
            steps {  
                script {  
                    echo "Building the Docker image..."  

                    // ✅ What it does: Builds, logs into Docker Hub, and pushes the Docker image using secure credentials  
                    // 🧠 Why it matters: Automates container image creation and upload for deployment use  
                    withCredentials([usernamePassword(credentialsId: 'docker-hub-repo', passwordVariable: 'PASS', usernameVariable: 'USER')]) {  
                        sh "docker build -t cdickersoncloudcoder/demo-app:${IMAGE_NAME} ."  
                        sh 'echo $PASS | docker login -u $USER --password-stdin'  
                        sh "docker push cdickersoncloudcoder/demo-app:${IMAGE_NAME}"  
                    }  
                }  
            }  
        }  

        stage('deploy') {  
            steps {  
                script {  
                    echo 'Deploying Docker image...'  

                    // ✅ What it does: Placeholder to add deployment commands (e.g., Kubernetes, ECS)  
                    // 🧠 Why it matters: Enables automated deployment as part of CI/CD pipeline  
                }  
            }  
        }  

        stage('commit version update') {  
            steps {  
                script {  
                    echo 'Committing version update back to GitLab...'  

                    // ✅ What it does: Configures git, commits version bump, and pushes changes to a branch securely  
                    // 🧠 Why it matters: Keeps version changes tracked in source control, enabling audit and collaboration  
                    withCredentials([usernamePassword(credentialsId: 'gitlab-credentials', passwordVariable: 'PASS', usernameVariable: 'USER')]) {  
                        sh 'git config --global user.email "jenkins@example.com"'  
                        sh 'git config --global user.name "jenkins"'  
                        sh 'git status'                                 // ✅ Shows current git status (for debugging if needed)  
                        sh 'git branch'                                 // ✅ Lists branches for context  
                        sh 'git config --list'                          // ✅ Outputs git config for verification  
                        sh """  
                        git remote set-url origin https://${USER}:${PASS}@gitlab.com/cdickersoncloudcoder/java-maven-app.git  
                        """                                              // ✅ Updates remote URL to include credentials for push  
                        sh 'git add .'                                  // ✅ Stages all changes (e.g., pom.xml version update)  
                        sh 'git commit -m "ci: version bump"'           // ✅ Commits changes with a clear message  
                        sh 'git push origin HEAD:jenkins-jobs'          // ✅ Pushes to jenkins-jobs branch securely  
                    }  
                }  
            }  
        }  
    }  
}  

// ------------------------------  
// ▶️ HOW TO RUN / EXECUTE THIS PIPELINE  
// ------------------------------  
// 1. Ensure Jenkins agent has Maven 3.9, Docker CLI, and git installed/configured.  
// 2. Create Jenkins credentials:  
//    - 'docker-hub-repo' for Docker Hub (username/password).  
//    - 'gitlab-credentials' for GitLab (username/password or personal access token as password).  
// 3. Commit this Jenkinsfile to your repository root.  
// 4. Trigger the pipeline manually or via webhook on repository changes.  
// 5. The pipeline will bump version, build JAR, build & push Docker image, and commit the new version to GitLab.  

// ------------------------------  
// ✅ NOTES / GOTCHAS / TIPS  
// ------------------------------  
// - Escaping in `mvn` command (\\\${parsedVersion...}) is required for multi-line shell scripts.  
// - Replace 'cdickersoncloudcoder' with your Docker Hub namespace.  
// - Replace git remote URL to point to your GitLab project.  
// - If git push fails, ensure Jenkins agent has network access and that credentials have push rights.  
// - Consider adding a pre-check stage for git clean workspace to avoid merge conflicts.  
// - You can expand the 'deploy' stage with kubectl, helm, or ECS CLI for actual deployments.  
