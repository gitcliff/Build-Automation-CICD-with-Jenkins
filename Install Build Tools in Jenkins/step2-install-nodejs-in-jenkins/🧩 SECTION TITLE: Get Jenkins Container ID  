# 📦 SUMMARY  
# These commands get the Jenkins container ID, enter its shell as root, install Node.js 20.x and npm inside the container, and verify the installation.  
# Language/Platform: Bash (Linux/macOS) and Docker  
# What you'll learn: Listing containers, entering containers as root, installing packages, and setting up Node.js inside a running Docker container  
# Outcome: Jenkins container will have Node.js and npm installed, enabling it to run Node-based build steps or pipelines  
# Why this matters: Some Jenkins jobs require Node.js (e.g., building React apps, running npm scripts) and installing it in the container makes them work without modifying the Docker image  

ssh root@DropletIp
# ------------------------------  
# 🧩 SECTION TITLE: Get Jenkins Container ID  
# ------------------------------  
docker ps  
# ✅ What it does: Lists all running containers, showing IDs, names, and ports  
# 🧠 Why it matters: Needed to identify the Jenkins container’s ID to use with `docker exec`  

# ------------------------------  
# 🧩 SECTION TITLE: Enter Jenkins Container Shell as Root  
# ------------------------------  
docker exec -u 0 -it <container-id> bash  
# ✅ What it does: Opens an interactive shell inside the container as user `root` (`-u 0` means UID 0 = root)  
# 🧠 Why it matters: Running as root allows package installation and configuration changes in the container  

# ------------------------------  
# 🧩 SECTION TITLE: Confirm Base OS in Container  
# ------------------------------  
cat /etc/issue  
# ✅ What it does: Prints the OS version string of the container’s base image  
# 🧠 Why it matters: Helps tailor commands for Debian-based or other OS families  
# 🔥 Example output: `Debian GNU/Linux 12 \n \l`  

# ------------------------------  
# 🧩 SECTION TITLE: Update Package List and Install curl  
# ------------------------------  
apt update  
# ✅ What it does: Updates apt package metadata to ensure latest versions are available  
# 🧠 Why it matters: Required before installing new packages  

apt install curl  
# ✅ What it does: Installs `curl`, a tool to download files from URLs  
# 🧠 Why it matters: Needed to fetch Node.js setup script from NodeSource  

# ------------------------------  
# 🧩 SECTION TITLE: Download and Run Node.js Setup Script  
# ------------------------------  

# Step 1: Download the setup script
curl -sL https://deb.nodesource.com/setup_20.x -o nodesource_setup.sh  
# ✅ What it does: Gets a script from NodeSource that tells your system where to find Node.js 20.x.  
# 🧠 Why it matters: Linux doesn’t know the latest Node.js by default.  
#    Without this script, `apt install nodejs` would give an old version.  
# 🧠 How it works:  
#    - curl = tool to download files from the internet  
#    - -s = silent, hides progress  
#    - -L = follow redirects if the URL moves  
#    - -o nodesource_setup.sh = save the file as nodesource_setup.sh  

# Step 2: Run the setup script
bash nodesource_setup.sh  
# ✅ What it does: Runs the script you just downloaded.  
# 🧠 Why it matters: It sets up your system to install Node.js 20.x safely.  
#    Specifically, it does two things:  
#      1. Adds the NodeSource repository to your system (so apt knows where to get Node.js).  
#      2. Adds a GPG key to make sure packages are trusted and not tampered with.  
# 🧠 How it works:  
#    - `bash` executes the script like a mini-program.  
#    - After it runs, you can run `sudo apt install -y nodejs` and get the right version.  
#    - It’s like telling your system: “Here’s the official place to download Node.js, and it’s safe.”  

# ✅ In short:  
# 1. curl downloads the instructions.  
# 2. bash runs the instructions to prepare your system.  
# 3. After this, installing Node.js is easy and safe.  

# ------------------------------  
# ⚙️ NEXT STEP: Install Node.js  
# ------------------------------  
# sudo apt install -y nodejs  
# ✅ What it does: Actually installs Node.js 20.x using the repository added by the script.  
# 🧠 Why it matters: Now your system can run Node.js programs and Jenkins can use it for builds.  
# 🧠 How it works: apt reads the NodeSource repository and downloads the latest Node.js package.  


# ------------------------------  
# 🧩 SECTION TITLE: Install Node.js and npm  
# ------------------------------  
apt install nodejs  
# ✅ What it does: Installs Node.js 20.x and npm (Node package manager) from NodeSource repo  
# 🧠 Why it matters: Makes Node.js tools available for Jenkins pipelines  

# ------------------------------  
# 🧪 SECTION TITLE: Verify Installations  
# ------------------------------  
node -v  
# ✅ What it does: Prints installed Node.js version (e.g., `v20.19.2`)  
# 🧠 Why it matters: Confirms Node.js is installed and working  

npm -v  
# ✅ What it does: Prints installed npm version (e.g., `10.8.2`)  
# 🧠 Why it matters: Confirms npm (needed for package management) is installed  

# ------------------------------  
# ✅ NOTES / GOTCHAS / TIPS  
# ------------------------------  
# - Replace `<container-id>` with Jenkins container ID from `docker ps`.  
# - Changes made this way are **temporary**. If the container is destroyed, they’re lost unless baked into a new image.  
# - To make permanent, create a Dockerfile based on `jenkins/jenkins:lts` and install Node.js there.  
# - Use `apt install -y <package>` to skip interactive confirmation prompts.  
# - Always update package lists before installing to avoid “package not found” errors.  
